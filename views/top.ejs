<!DOCTYPE html>
<html lang="<%= langCode %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title><%= t.topAnime %> — Anime Search Engine</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="navbar navbar-dark sticky-top px-3 py-2" id="main-nav">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <img src="https://avatars.githubusercontent.com/u/246539416?s=96&v=4" class="brand-logo rounded" alt="Logo" style="width:32px;height:32px;object-fit:cover;" />
      <span>Anime Search Engine</span>
    </a>
    <div class="d-flex gap-2 align-items-center">
      <a href="/top?lang=<%= langCode === 'en' ? 'kh' : 'en' %>" class="btn btn-sm btn-outline-warning">
        <i class="bi bi-translate"></i> <%= langCode === 'en' ? 'KH' : 'EN' %>
      </a>
      <a href="/?lang=<%= langCode %>" class="btn btn-sm btn-outline-light"><%= t.search %></a>
      <a href="/top?lang=<%= langCode %>" class="btn btn-sm btn-outline-light active"><%= t.top %></a>
    </div>
  </nav>

  <main class="container py-3">
    <h2 class="h5 fw-bold text-white mb-3"><i class="bi bi-trophy-fill text-warning me-2"></i><%= t.topAnime %></h2>

    <% if (results.length === 0) { %>
    <div class="text-center py-5"><div class="fs-1">😢</div><p class="text-muted"><%= t.cantLoad %></p></div>
    <% } else { %>
    <div class="list-group gap-2">
      <% results.forEach((anime, i) => { %>
      <a href="/anime/<%= anime.mal_id %>?lang=<%= langCode %>" class="list-group-item list-group-item-action d-flex gap-3 align-items-center top-item rounded">
        <div class="rank-badge fw-bold text-center <%= i < 3 ? 'text-warning' : 'text-muted' %>">
          #<%= i + 1 %>
        </div>
        <img src="<%= anime.images.jpg.image_url %>" class="top-thumb rounded" alt="<%= anime.title %>" />
        <div class="flex-grow-1 min-w-0">
          <p class="fw-semibold mb-0 text-white text-truncate"><%= anime.title %></p>
          <div class="d-flex gap-2 mt-1 flex-wrap">
            <% if (anime.score) { %><span class="text-warning small"><i class="bi bi-star-fill"></i> <%= anime.score %></span><% } %>
            <% if (anime.episodes) { %><span class="text-muted small"><i class="bi bi-collection-play"></i> <%= anime.episodes %> <%= t.episodes %></span><% } %>
            <% if (anime.year) { %><span class="text-muted small"><i class="bi bi-calendar3"></i> <%= anime.year %></span><% } %>
          </div>
          <div class="d-flex flex-wrap gap-1 mt-1">
            <% (anime.genres || []).slice(0,3).forEach(g => { %>
            <span class="badge bg-primary" style="font-size:0.6rem"><%= g.name %></span>
            <% }) %>
          </div>
        </div>
      </a>
      <% }) %>
    </div>
    <% } %>
  </main>

  <footer class="text-center py-3 mt-4" id="footer">
    <small class="text-muted">
      Powered by <a href="https://jikan.moe" target="_blank">Jikan API</a> · 
      Made by <a href="https://github.com/blaxkmiradev" target="_blank">Rikixz</a>
    </small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!DOCTYPE html>
<html lang="<%= langCode %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no" />
  <title><%= t.title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-dark sticky-top px-3 py-2" id="main-nav">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="/">
      <img src="https://avatars.githubusercontent.com/u/246539416?s=96&v=4" class="brand-logo rounded" alt="Logo" />
      <span>Anime Search Engine</span>
    </a>
    <div class="d-flex gap-2 align-items-center">
      <!-- Language Switcher -->
      <a href="/?lang=<%= langCode === 'en' ? 'kh' : 'en' %>&q=<%= encodeURIComponent(query.q||'') %>&genre=<%= query.genre||'' %>&year=<%= query.year||'' %>" 
         class="btn btn-sm btn-outline-warning lang-switch">
        <i class="bi bi-translate me-1"></i><%= t.langSwitch %>
      </a>
      <a href="/" class="btn btn-sm btn-outline-light <%= !query.q && !query.genre && !query.year ? 'active' : '' %>"><%= t.search %></a>
      <a href="/top?lang=<%= langCode %>" class="btn btn-sm btn-outline-light"><%= t.top %></a>
    </div>
  </nav>

  <main class="container py-3">

    <!-- Hero -->
    <% if (!query.q && !query.genre && !query.year) { %>
    <div class="hero-section text-center py-4 mb-3">
      <h1 class="display-6 fw-bold text-white"><%= t.heroTitle %></h1>
      <p class="text-muted mb-0"><%= t.heroDesc %></p>
    </div>
    <% } %>

    <!-- Search Form -->
    <form action="/" method="GET" id="search-form">
      <input type="hidden" name="lang" value="<%= langCode %>" />
      <div class="search-card card shadow-sm mb-4">
        <div class="card-body p-3">
          <!-- Title input -->
          <div class="input-group mb-3">
            <span class="input-group-text bg-dark border-secondary text-white"><i class="bi bi-search"></i></span>
            <input
              type="text"
              name="q"
              class="form-control bg-dark text-white border-secondary"
              placeholder="<%= t.searchPlaceholder %>"
              value="<%= query.q || '' %>"
              autocomplete="off"
            />
            <button class="btn btn-primary px-3" type="submit"><%= t.search %></button>
          </div>

          <!-- Filters row -->
          <div class="row g-2">
            <div class="col-7">
              <select name="genre" class="form-select form-select-sm bg-dark text-white border-secondary">
                <option value=""><%= t.allGenres %></option>
                <% genres.forEach(g => { %>
                <option value="<%= g.mal_id %>" <%= query.genre == g.mal_id ? 'selected' : '' %>><%= g.name %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-5">
              <input
                type="number"
                name="year"
                class="form-control form-control-sm bg-dark text-white border-secondary"
                placeholder="<%= t.yearPlaceholder %>"
                value="<%= query.year || '' %>"
                min="1960"
                max="2026"
              />
            </div>
          </div>
        </div>
      </div>
    </form>

    <!-- Error -->
    <% if (error) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i><%= error %></div>
    <% } %>

    <!-- Results -->
    <% if (results.length > 0) { %>
    <p class="text-muted small mb-3"><%= t.found %> <%= pagination ? pagination.items.total : results.length %>+ <%= t.results %></p>

    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
      <% results.forEach(anime => { %>
      <div class="col">
        <a href="/anime/<%= anime.mal_id %>?lang=<%= langCode %>" class="text-decoration-none">
          <div class="card anime-card h-100 shadow-sm">
            <div class="position-relative">
              <img
                src="<%= anime.images.jpg.large_image_url || anime.images.jpg.image_url %>"
                class="card-img-top anime-thumb"
                alt="<%= anime.title %>"
                loading="lazy"
              />
              <% if (anime.score) { %>
              <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-1 fw-bold">
                <i class="bi bi-star-fill me-1"></i><%= anime.score %>
              </span>
              <% } %>
              <% if (anime.type) { %>
              <span class="badge bg-dark bg-opacity-75 position-absolute top-0 start-0 m-1"><%= anime.type %></span>
              <% } %>
            </div>
            <div class="card-body p-2">
              <p class="card-title fw-semibold small mb-1 anime-title"><%= anime.title %></p>
              <div class="d-flex flex-wrap gap-1">
                <% if (anime.episodes) { %>
                <span class="badge bg-secondary"><i class="bi bi-collection-play me-1"></i><%= anime.episodes %> <%= t.episodes %></span>
                <% } %>
                <% if (anime.status) { %>
                <span class="badge <%= anime.status === 'Currently Airing' ? 'bg-success' : 'bg-secondary' %>"><%= anime.status === 'Currently Airing' ? t.airing : (anime.status === 'Finished Airing' ? t.finished : anime.status) %></span>
                <% } %>
              </div>
            </div>
          </div>
        </a>
      </div>
      <% }) %>
    </div>

    <!-- Pagination -->
    <% if (pagination && pagination.last_visible_page > 1) { %>
    <nav class="mt-4">
      <ul class="pagination justify-content-center flex-wrap gap-1">
        <% const currentPage = parseInt(query.page) || 1; %>
        <% const totalPages = Math.min(pagination.last_visible_page, 10); %>

        <% if (currentPage > 1) { %>
        <li class="page-item">
          <a class="page-link" href="?lang=<%= langCode %>&q=<%= encodeURIComponent(query.q||'') %>&genre=<%= query.genre||'' %>&year=<%= query.year||'' %>&page=<%= currentPage-1 %>">
            <i class="bi bi-chevron-left"></i>
          </a>
        </li>
        <% } %>

        <% for (let i = Math.max(1, currentPage-2); i <= Math.min(totalPages, currentPage+2); i++) { %>
        <li class="page-item <%= i === currentPage ? 'active' : '' %>">
          <a class="page-link" href="?lang=<%= langCode %>&q=<%= encodeURIComponent(query.q||'') %>&genre=<%= query.genre||'' %>&year=<%= query.year||'' %>&page=<%= i %>"><%= i %></a>
        </li>
        <% } %>

        <% if (currentPage < totalPages) { %>
        <li class="page-item">
          <a class="page-link" href="?lang=<%= langCode %>&q=<%= encodeURIComponent(query.q||'') %>&genre=<%= query.genre||'' %>&year=<%= query.year||'' %>&page=<%= currentPage+1 %>">
            <i class="bi bi-chevron-right"></i>
          </a>
        </li>
        <% } %>
      </ul>
    </nav>
    <% } %>

    <% } else if (query.q || query.genre || query.year) { %>
    <div class="text-center py-5">
      <div class="fs-1">😢</div>
      <p class="text-muted"><%= t.noResults %></p>
    </div>
    <% } else { %>
    <!-- Default: show popular tags -->
    <div class="text-center py-2">
      <p class="text-muted small mb-3"><%= t.popularGenres %></p>
      <div class="d-flex flex-wrap justify-content-center gap-2">
        <% const popularGenres = genres.slice(0, 12); popularGenres.forEach(g => { %>
        <a href="/?lang=<%= langCode %>&genre=<%= g.mal_id %>" class="btn btn-sm btn-outline-secondary genre-pill"><%= g.name %></a>
        <% }) %>
      </div>
    </div>
    <% } %>

  </main>

  <footer class="text-center py-3 mt-4" id="footer">
    <small class="text-muted">
      Powered by <a href="https://jikan.moe" target="_blank">Jikan API</a> · 
      Made by <a href="https://github.com/blaxkmiradev" target="_blank">Rikixz</a>
    </small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
